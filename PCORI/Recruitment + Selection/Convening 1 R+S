# -----------------------------------------------------------------------------
# Function to fill missing RUCA codes from ZIP code lookup
# -----------------------------------------------------------------------------

fill_missing_ruca <- function(data, zip_field, ruca_field, ruca_lookup) {
  if (!RUCA_LOOKUP_AVAILABLE) {
    return(data)
  }
  
  # Get current RUCA values and ZIP codes
  current_ruca <- data[[ruca_field]]
  zip_codes <- data[[zip_field]]
  
  # Count missing before
  n_missing_before <- sum(is.na(current_ruca) | current_ruca == "")
  
  # Clean ZIP codes for matching (handle various formats)
  zip_clean <- sapply(zip_codes, function(z) {
    if (is.na(z) || z == "") return(NA)
    # Extract first 5 digits (handle ZIP+4 format like "12345-6789")
    z_str <- as.character(z)
    z_str <- gsub("[^0-9]", "", z_str)  # Remove non-numeric
    if (nchar(z_str) >= 5) {
      return(sprintf("%05d", as.integer(substr(z_str, 1, 5))))
    }
    return(NA)
  })
  
  # Fill missing RUCA codes
  filled_ruca <- sapply(1:length(current_ruca), function(i) {
    # If RUCA already exists, keep it
    if (!is.na(current_ruca[i]) && current_ruca[i] != "" && current_ruca[i] != 0) {
      return(current_ruca[i])
    }
    
    # Otherwise, look up from ZIP code
    if (!is.na(zip_clean[i])) {
      match_idx <- which(ruca_lookup$zip_code_clean == zip_clean[i])
      if (length(match_idx) > 0) {
        return(ruca_lookup$ruca_primary[match_idx[1]])
      }
    }
    
    return(NA)
  })
  
  # Update the data
  data[[ruca_field]] <- filled_ruca
  
  # Count filled
  n_missing_after <- sum(is.na(filled_ruca) | filled_ruca == "")
  n_filled <- n_missing_before - n_missing_after
  
  cat(sprintf("  RUCA codes filled from ZIP lookup: %d of %d missing\n", 
              n_filled, n_missing_before))
  cat(sprintf("  Remaining without RUCA: %d\n", n_missing_after))
  
  return(data)
}

