      race_raw %in% c("6", 6) ~ "Multiracial",
      TRUE ~ "Other"
    ),
    
    ethnicity_raw = .data[[FIELD_NAMES$ethnicity]],
    is_hispanic = ethnicity_raw %in% c(1, "1"),  # 1=Hispanic, 0=Non-Hispanic
